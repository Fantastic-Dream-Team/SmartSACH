APP_ORIGIN=http://localhost:8000
# En Render con Supabase usa el Session pooler, no db.PROJECT_REF.supabase.co.
# Ejemplo: aws-0-us-east-1.pooler.supabase.com
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_recoleccion
# En el pooler de Supabase suele ser postgres.PROJECT_REF.
DB_USER=postgres
DB_PASS=
DB_SSLMODE=prefer
